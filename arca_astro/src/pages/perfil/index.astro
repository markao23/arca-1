---
import '../../styles/global.css';
// src/pages/perfil.astro (ou um componente em src/components/ProfileCard.astro)
---

<div class="bg-gray-100 py-12">
    <div class="max-w-3xl mx-auto bg-white shadow-lg rounded-lg overflow-hidden">
      <div class="px-4 py-5 sm:px-6 bg-gray-200">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Meu Perfil
        </h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">
          Informacoes pessoais e links relevantes.
        </p>
      </div>
      <div class="border-t border-gray-200">
        <dl>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Foto de Perfil
            </dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <div class="relative rounded-full h-24 w-24 overflow-hidden">
                <img src="/images/avatar-placeholder.png" alt="Sua foto de perfil" class="object-cover h-full w-full" />
                </div>
            </dd>
          </div>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Nome Completo
            </dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              Markus Silva
              </dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Bio
            </dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              Desenvolvedor Full-Stack apaixonado por tecnologia e aprendizado contínuo. Explorando o mundo do Front-end com React e Astro, e construindo Back-ends robustos com Node.js e Java. Fascinado por Inteligência Artificial e solucoes inovadoras.
              </dd>
          </div>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Localização
            </dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              Catanduva, Sao Paulo, Brasil
              </dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Email
            </dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              markus.silva@email.com
              </dd>
          </div>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Links Sociais
            </dt>
            <dd class="mt-2 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul role="list" class="flex space-x-4">
                <li>
                  <a href="https://github.com/seunome" class="text-blue-500 hover:text-blue-700">
                    GitHub
                  </a>
                </li>
                <li>
                  <a href="https://linkedin.com/in/seunome" class="text-blue-700 hover:text-blue-900">
                    LinkedIn
                  </a>
                </li>
                <li>
                  <a href="https://twitter.com/seunome" class="text-blue-400 hover:text-blue-600">
                    Twitter
                  </a>
                </li>
                </ul>
            </dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">
              Habilidades
            </dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul role="list" class="flex flex-wrap gap-2">
                <li class="bg-blue-200 text-blue-700 rounded-full px-3 py-1 text-xs font-semibold">JavaScript</li>
                <li class="bg-blue-200 text-blue-700 rounded-full px-3 py-1 text-xs font-semibold">React</li>
                <li class="bg-blue-200 text-blue-700 rounded-full px-3 py-1 text-xs font-semibold">Astro</li>
                <li class="bg-green-200 text-green-700 rounded-full px-3 py-1 text-xs font-semibold">Node.js</li>
                <li class="bg-yellow-200 text-yellow-700 rounded-full px-3 py-1 text-xs font-semibold">Tailwind CSS</li>
                <li class="bg-red-200 text-red-700 rounded-full px-3 py-1 text-xs font-semibold">Java</li>
                </ul>
            </dd>
          </div>
          {/* Você pode adicionar mais informações aqui, como experiência profissional, educação, projetos, etc. */}
        </dl>
      </div>
    </div>
  </div>
  
  <style>
    /* Você pode adicionar estilos personalizados aqui se precisar */
  </style>
  
  <script>
    // Você pode adicionar scripts aqui se precisar de alguma interatividade
  </script>