---
// Se você tiver um Layout.astro configurado, descomente as linhas abaixo:
// import Layout from '../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import '../../styles/global.css'

---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suporte | Arca</title>
</head>
<body class="bg-[#0B0D14] text-white min-h-screen font-sans overflow-x-hidden flex flex-col relative">

    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-purple-900/20 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-teal-900/20 blur-[120px] rounded-full"></div>
    </div>

    <div class="relative z-10 flex flex-col min-h-screen">
        <header class="flex items-center justify-between px-8 py-5 border-b border-white/5 bg-[#0B0D14]/80 backdrop-blur-md">
            <Navbar />
        </header>

        <main class="flex-grow max-w-5xl w-full mx-auto px-8 py-12">
            <div class="mb-10">
                <h1 class="text-4xl font-bold tracking-tight mb-2 flex items-center gap-3">
                    Central de Suporte 🎧
                </h1>
                <p class="text-gray-400 text-sm">Como podemos ajudar você hoje, Markus?</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <a href="#" class="bg-white/[0.03] border border-white/10 rounded-[24px] p-6 flex flex-col hover:bg-white/[0.06] transition-colors group">
                    <div class="w-12 h-12 rounded-full border border-purple-500/30 bg-purple-500/10 flex items-center justify-center mb-6 text-purple-400 group-hover:scale-110 transition-transform">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21h6M12 17v4M12 3a7 7 0 017 7c0 2.21-1.34 4.18-3.04 5.37C15 16.03 14 17.5 14 19H10c0-1.5-1-2.97-1.96-3.63C6.34 14.18 5 12.21 5 10a7 7 0 017-7z"></path></svg>
                    </div>
                    <span class="text-gray-400 text-sm font-medium mb-1">Autoatendimento</span>
                    <h2 class="text-2xl font-semibold text-white mb-2">FAQ</h2>
                    <p class="text-gray-500 text-sm mt-auto">Acesse nossos artigos e tutoriais.</p>
                </a>
                <a href="#" class="bg-white/[0.03] border border-white/10 rounded-[24px] p-6 flex flex-col hover:bg-white/[0.06] transition-colors group">
                    <div class="w-12 h-12 rounded-full border border-teal-500/30 bg-teal-500/10 flex items-center justify-center mb-6 text-teal-400 group-hover:scale-110 transition-transform">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                    </div>
                    <span class="text-gray-400 text-sm font-medium mb-1">Falar com Humano</span>
                    <h2 class="text-2xl font-semibold text-white mb-2">Chat ao Vivo</h2>
                    <p class="text-gray-500 text-sm mt-auto">Tempo de espera: ~5 min.</p>
                </a>
                <div class="relative rounded-[24px] p-[1px] bg-gradient-to-b from-blue-500/60 to-purple-500/10 group cursor-pointer hover:from-blue-400/80 transition-all shadow-[0_0_30px_rgba(59,130,246,0.15)]">
                    <div class="bg-[#111622] h-full w-full rounded-[23px] p-6 flex flex-col items-center justify-center text-center relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1/2 bg-blue-500/10 blur-[30px] rounded-full pointer-events-none"></div>
                        <div class="w-14 h-14 rounded-full bg-blue-600 flex items-center justify-center text-white mb-4 shadow-[0_0_20px_rgba(59,130,246,0.6)] group-hover:scale-110 transition-transform relative z-10">
                            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
                        </div>
                        <h2 class="text-xl font-semibold text-white relative z-10 mb-1">Abrir Chamado</h2>
                        <p class="text-blue-200/60 text-sm relative z-10">Relatar um problema complexo para a equipe técnica</p>
                    </div>
                </div>
            </div>
        </main>

        <Footer />

    </div>
</body>
</html>