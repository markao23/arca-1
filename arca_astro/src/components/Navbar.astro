---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
import "../styles/global.css";

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const menuItems = [
  { text: "Perfil", href: "/perfil" },
  { text: "Calendário", href: "/calendario" },
  { text: "Pagamento", href: "/pagamento" },
  { text: "Cadastrar", href: "/cadastrar" },
];

const getMobileHref = (path: string) => {
  if (path === '/') {
    return '/index.html'
  }
  return path.endsWith('.html') ? path : `${path.replace(/\/$/, "")}/index.html`
}

const isActive = (itemHref: string) => {
  const mobile = getMobileHref(itemHref);

  return currentPath === itemHref || currentPath === mobile || currentPath === `${itemHref}/`
}
---

<div class="fixed top-3 inset-x-0 flex justify-center z-50 pointer-events-none px-2 md:px-4">
  <header class="pointer-events-auto w-full max-w-4xl bg-[#0A0A0A]/75 backdrop-blur-xl border border-white/[0.08] shadow-[0_8px_32px_rgba(0,0,0,0.5)]
    rounded-full px-3 py-2 flex items-center justify-between transition-all duration-500">
    
    <a href="/" class="flex items-center gap-2 md:gap-3 group focus:outline-none" aria-label="pagina principal">
      <div class="relative flex items-center justify-center">
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-full blur 
          opacity-0 group-hover:opacity-40 transition-opacity duration-500"></div>
        <Image src={logo} alt="Logo" class="relative h-7 w-7 md:h-8 md:w-8 object-contain z-10"/>
      </div>
      <span class="text-base md:text-lg font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-100 to-gray-400 tracking-wide">
        ARCA
      </span>
    </a>

    <nav class="hidden md:flex items-center p-1 bg-white/[0.02] border border-white/[0.04] rounded-full shadow-inner">
      <ul class="flex items-center gap-1">
        {menuItems.map((item) => (
          <li>
            <a href={getMobileHref(item.href)} class:list={[
              "relative px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-300 inline-block hover:text-white hover:bg-white/[0.06]",
              {
                "text-white bg-white/[0.08] shadow-sm border border-white/[0.05]": currentPath === item.href,
                "text-gray-400 border border-transparent": currentPath != item.href
              }
            ]}>
              {item.text}
            </a>
          </li> 
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-3 md:gap-4 pr-1">
      <form action="/process" method="post" id="libravatarForm" class="flex items-center gap-3 md:gap-4">
        <div class="relative group cursor-pointer"> 
          <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-cyan-500 
            rounded-full opacity-0 group-hover:opacity-40 blur transition duration-300"></div>
          <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" alt="avatar" class="relative h-7 w-7 md:h-8 md:w-8 rounded-full object-cover border border-white/[0.1] bg-gray-900">
          <span class="absolute bottom-0 right-0 h-2.5 w-2.5 bg-emerald-500 border-[2px] border-[#0A0A0A] rounded-full"></span>
        </div>
        
        <div class="h-4 w-[1px] bg-white/[0.1]"></div>
        
        <a href="/login" class="text-gray-500 hover:text-red-400 transition-colors p-1 rounded-full hover:bg-red-500/10 focus:outline-none flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
        </a>
      </form>

      <button id="btn-hamburguer" type="button" class="md:hidden text-gray-400 hover:text-white focus:outline-none p-1 transition-colors" aria-label="Abrir menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </header>

  <div id="menu-mobile" class="hidden md:hidden absolute top-14 left-0 w-full pt-2 z-[9999] pointer-events-auto">
    <div class="bg-[#0A0A0A]/95 backdrop-blur-xl border border-white/[0.08] shadow-[0_8px_32px_rgba(0,0,0,0.5)] rounded-2xl p-2 flex flex-col gap-1 pointer-events-auto">
      
      {menuItems.map((item) => (
        <a href={item.href} class:list={[
          "block w-full px-4 py-3 text-sm font-medium rounded-xl transition-all duration-300 hover:bg-white/[0.06] hover:text-white pointer-events-auto cursor-pointer",
          {
            "text-white bg-white/[0.08] border border-white/[0.05]": currentPath === item.href,
            "text-gray-400 border border-transparent": currentPath != item.href
          }
        ]}>
          {item.text}
        </a>
      ))}
  
    </div>
  </div>
</div>


<script>
  const btn = document.getElementById('btn-hamburguer');
  const menu = document.getElementById('menu-mobile');

  // Apenas liga e desliga o menu. A navegação será feita nativamente pelo HTML!
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
