---
// src/components/Navbar.astro
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
import "../styles/global.css";

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const menuItems = [
  { text: "Perfil", href: "/perfil" },
  { text: "Calendário", href: "/calendario" },
  { text: "Pagamento", href: "/pagamento" },
  { text: "Cadastrar", href: "/cadastrar" },
];
---

<div class="fixed top-3 inset-x-0 flex justify-center z-50 pointer-events-none px-4">
  <header class="pointer-events-auto w-full max-w-4xl bg-[#0A0A0A]/75 backdrop-blur-xl border border-white/[0.08] shadow-[0_8px_32px_rgba(0,0,0,0.5)] rounded-full px-3 py-2 flex items-center justify-between transition-all duration-500">
    <a 
      href="/" 
      class="flex items-center gap-3 pl-2 group focus:outline-none"
      aria-label="Página Principal"
    >
      <div class="relative flex items-center justify-center">
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-full blur opacity-0 group-hover:opacity-40 transition-opacity duration-500"></div>
        <Image class="relative h-7 w-7 object-contain z-10" src={logo} alt="Logo Arca" />
      </div>
      <span class="text-base font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-100 to-gray-400 tracking-wide">
        Arca
      </span>
    </a>

    <nav class="hidden md:flex items-center p-1 bg-white/[0.02] border border-white/[0.04] rounded-full shadow-inner" aria-label="Navegação">
      <ul class="flex items-center gap-1">
        {menuItems.map((item) => {
          const isActive = currentPath === item.href;
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  "relative px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-300 inline-block",
                  "hover:text-white hover:bg-white/[0.06]",
                  isActive 
                    ? "text-white bg-white/[0.08] shadow-sm border border-white/[0.05]" 
                    : "text-gray-400 border border-transparent"
                ]}
              >
                {item.text}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="flex items-center gap-4 pr-1">
      <form 
        id="libravatarForm" 
        action="/process" 
        method="post" 
        class="flex items-center gap-4"
      >
        <div class="relative group cursor-pointer">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-full opacity-0 group-hover:opacity-40 blur transition duration-300"></div>
          <img
            id="libravatarImagem"
            src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" 
            alt="Avatar"
            class="relative h-8 w-8 rounded-full object-cover border border-white/[0.1] bg-gray-900"
          />
          <span class="absolute bottom-0 right-0 h-2.5 w-2.5 bg-emerald-500 border-[2px] border-[#0A0A0A] rounded-full"></span>
        </div>

        <div class="h-4 w-[1px] bg-white/[0.1]"></div>

        <a 
          href="/login" 
          class="text-gray-500 hover:text-red-400 transition-colors p-1.5 rounded-full hover:bg-red-500/10 focus:outline-none flex items-center justify-center"
          title="Sair"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
        </a>
      </form>
    </div>