---
const ano = new Date().getFullYear();
const versão = "v1.0.0";
---

<footer class="w-full max-w-5xl mx-quto mt-auto pt-3 pb-6 border-t border-white/[0.05] animate-fade-in">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 px-4 text-xs text-gray-500">
        <p class="whitespace-nowrap">&copy; {ano} ARCA. Todos os direitos reservados.</p>
        <nav class="flex gap-6">
            <a href="/suporte" class="hover:text-indigo-400 transition-colors">Suporte</a>
            <a href="/termo" class="hover:text-indigo-400 transition-colors whitespace-nowrap">Termos de Uso</a>
            <a href="/privacidade" class="hover:text-indigo-400 transition-colors">Privacidade</a>
        </nav>
        <div class="flex items-center gap-2 bg-white/[0.02] px-3 py-1.5 rounded-full border border-white/[0.05]">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-flull rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="whitespace-nowrap">Sistema Operacional • {versão}</span>
        </div>
    </div>
</footer>